{
  "$schema": "https://raw.githubusercontent.com/nickkuk/tauri-docs/v2/references/config-schema.json",
  "productName": "TokenFence Studio",
  "version": "0.4.0-dev",
  "identifier": "com.tokenfence.studio",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../ui && npm install && npm run build",
    "beforeDevCommand": "cd ../ui && npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "TokenFence Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
